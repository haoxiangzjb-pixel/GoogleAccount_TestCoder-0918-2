# Простое правило для компиляции программы на C
# Предполагается, что исходный файл называется program.c

CC = gcc
CFLAGS = -Wall -g # Флаги для компилятора: предупреждения и отладочная информация

# Целевая цель по умолчанию
all: program

# Правило для компиляции исполняемого файла program из program.c
program: program.c
	$(CC) $(CFLAGS) -o program program.c

# Правило для очистки скомпилированных файлов
clean:
	rm -f program

# Псевдоним для очистки
.PHONY: all clean