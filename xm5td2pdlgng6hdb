# Chef Resource para gestionar archivos
# Nombre aleatorio: xm5td2pdlgng6hdb

property :path, String, name_property: true
property :content, String, default: ''
property :mode, String, default: '0644'
property :owner, String, default: 'root'
property :group, String, default: 'root'
property :action, String, default: 'create'
property :backup, [TrueClass, FalseClass], default: true
property :purge, [TrueClass, FalseClass], default: false

actions :create, :delete, :edit, :chmod, :chown

default_action :create

action :create do
  converge_if_changed :content do
    directory File.dirname(new_resource.path) do
      recursive true
      action :create
    end

    file new_resource.path do
      content new_resource.content
      mode new_resource.mode
      owner new_resource.owner
      group new_resource.group
      backup new_resource.backup if respond_to?(:backup)
      action :create
    end
  end
end

action :delete do
  file new_resource.path do
    action :delete
  end
end

action :chmod do
  file new_resource.path do
    mode new_resource.mode
    action :chmod
  end
end

action :chown do
  file new_resource.path do
    owner new_resource.owner
    group new_resource.group
    action :chown
  end
end

action :edit do
  file new_resource.path do
    content new_resource.content
    mode new_resource.mode
    owner new_resource.owner
    group new_resource.group
    action :create
  end
end

