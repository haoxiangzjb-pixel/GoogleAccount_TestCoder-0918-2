```
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
env/
.ENV/

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
htmlcov/
coverage/

# Python build artifacts
build/
dist/
*.egg-info/
*.egg

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# Git related (avoid ignoring actual git files)
!.gitignore
```