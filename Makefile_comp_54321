# Makefile for compiling a C program

CC = gcc
CFLAGS = -Wall -g
TARGET = hello
SOURCE = hello.c

# Default target
all: $(TARGET)

# Rule to compile the C program
$(TARGET): $(SOURCE)
	$(CC) $(CFLAGS) -o $(TARGET) $(SOURCE)

# Clean compiled files
clean:
	rm -f $(TARGET)

# Phony targets
.PHONY: all clean