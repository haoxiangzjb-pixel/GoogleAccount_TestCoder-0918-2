# Makefile for C++ project

# Compiler and flags
CXX = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -g
LDLIBS = 

# Directories
SRCDIR = src
TESTDIR = test
BUILDDIR = build
TARGET = $(BUILDDIR)/main
TESTTARGET = $(BUILDDIR)/test_runner

# Find all source files
SOURCES = $(wildcard $(SRCDIR)/*.cpp)
OBJECTS = $(SOURCES:$(SRCDIR)/%.cpp=$(BUILDDIR)/%.o)

TEST_SOURCES = $(wildcard $(TESTDIR)/*.cpp)
TEST_OBJECTS = $(TEST_SOURCES:$(TESTDIR)/%.cpp=$(BUILDDIR)/%.o)

# Default target
all: build

# Build target - creates the main executable
build: $(BUILDDIR) $(TARGET)

# Test target - builds and runs tests
test: $(BUILDDIR) $(TESTTARGET)
	@echo "Running tests..."
	./$(TESTTARGET)

# Create build directory
$(BUILDDIR):
	mkdir -p $(BUILDDIR)

# Link the main executable
$(TARGET): $(OBJECTS)
	@echo "Linking main executable..."
	$(CXX) $(CXXFLAGS) -o $@ $^ $(LDLIBS)

# Compile source files
$(BUILDDIR)/%.o: $(SRCDIR)/%.cpp
	@echo "Compiling $<..."
	$(CXX) $(CXXFLAGS) -c -o $@ $<

# Link the test executable
$(TESTTARGET): $(TEST_OBJECTS) $(filter-out $(BUILDDIR)/main.o, $(OBJECTS))
	@echo "Linking test executable..."
	$(CXX) $(CXXFLAGS) -o $@ $^ $(LDLIBS)

# Compile test files
$(BUILDDIR)/%.o: $(TESTDIR)/%.cpp
	@echo "Compiling test $<..."
	$(CXX) $(CXXFLAGS) -c -o $@ $<

# Clean target - removes build artifacts
clean:
	rm -rf $(BUILDDIR)
	@echo "Cleaned build directory."

# Phony targets
.PHONY: all build test clean